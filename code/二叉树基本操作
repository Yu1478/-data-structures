1、非递归便遍历：
#include <stdio.h>
#include <stdlib.h>

#define MAX 100

typedef struct TreeNode {
    int val;
    struct TreeNode* left;
    struct TreeNode* right;
} TreeNode;

TreeNode* stack[MAX];
int top = -1;

void push(TreeNode* node) {
    stack[++top] = node;
}

TreeNode* pop() {
    return stack[top--];
}

int isEmpty() {
    return top == -1;
}

void preorderNonRecursive(TreeNode* root) {

    if (root == NULL)
        return;

    push(root);

    while (!isEmpty()) {

        TreeNode* cur = pop();

        printf("%d ", cur->val);

        // 先右后左
        if (cur->right)
            push(cur->right);

        if (cur->left)
            push(cur->left);
    }
}
