7、BST插入（左子树小于根小于右子树）
TreeNode* insert(TreeNode* root, int val) {

    if (root == NULL)
        return createNode(val);

    if (val < root->val) {

        root->left = insert(root->left, val);

    } else {

        root->right = insert(root->right, val);
    }

    return root;
}

8、内存释放
void freeTree(TreeNode* root) {

    if (root == NULL)
        return;

    freeTree(root->left);

    freeTree(root->right);

    free(root);
}
9、构建完整的二叉树（递归）
treenode*build(){
     int val;
     scanf("%d",&val);
     if(val==-1) return NULL;
     treenode*root=creatnode(val);
     root->left=build();
     root->right=build();
     return root;
  }

10、复制子树
TreeNode* copyTree(TreeNode* root) {

    // 空树
    if (root == NULL)
        return NULL;

    // 复制当前节点
    TreeNode* newNode = createNode(root->val);

    // 复制左子树
    newNode->left = copyTree(root->left);

    // 复制右子树
    newNode->right = copyTree(root->right);

    return newNode;
}


