### 9. 最长有效括号

**描述**
给你一个只包含 ‘(’ 和 ‘)’ 的字符串，找出最长有效（格式正确且连续）括号子串的长度

**输入**
输入为一个只包含 ‘(’ 和 ‘)’ 的字符串，字符串长度<10000。

**输出**
输出为一个数字，表示最长有效括号子串的长度

```c
#include <stdio.h>
#include <string.h>
#include <stdlib.h>

#define MAXSIZE 10005

// 定义栈结构，用来存储括号的“下标”
typedef struct {
    int data[MAXSIZE]; 
    int top;
} Stack;

// 初始化栈
void initstack(Stack* s) {
    s->top = -1;
}

// 入栈
void push(Stack* s, int val) {
    if (s->top < MAXSIZE - 1) {
        s->data[++(s->top)] = val;
    }
}

// 出栈
void pop(Stack* s) {
    if (s->top != -1) {
        s->top--;
    }
}

// 获取最长有效括号长度
int validlength(char* a) {
    Stack s; // 在栈内存分配一个 Stack 变量
    initstack(&s);
    
    int maxLen = 0;
    
    // 【核心逻辑 1】：初始压入 -1 作为基准参照点
    // 这代表在下标 0 之前有一个虚拟的“断点”
    push(&s, -1);
    
    for (int i = 0; a[i] != '\0'; i++) {
        if (a[i] == '(') {
            // 【核心逻辑 2】：遇到左括号，把它的下标压入栈
            push(&s, i);
        } else {
            // 【核心逻辑 3】：遇到右括号，先弹出一个元素
            pop(&s);
            
            if (s.top == -1) {
                // 如果弹完后栈空了，说明刚才弹出的是“参照点”
                // 现在的右括号成了新的“参照断点”，压入它
                push(&s, i);
            } else {
                // 如果弹完后栈不空，说明匹配成功！
                // 当前长度 = 当前下标 - 此时的新栈顶下标
                int currentLen = i - s.data[s.top];
                if (currentLen > maxLen) {
                    maxLen = currentLen;
                }
            }
        }
    }
    return maxLen;
}

int main() {
    char a[MAXSIZE];
    // 读取输入的括号字符串
    if (scanf("%s", a) == 1) {
        printf("%d", validlength(a));
    }
    return 0;
}

```

