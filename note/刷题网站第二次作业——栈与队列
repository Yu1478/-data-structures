### 2. 回文链表

**描述**
“回文”指正读反读均相同的字符序列，如“abcdcba”和“abba”均是回文，使用栈这种数据结构判断给定字符序列是否为回文，要求使用链栈实现。

**输入**
一个字符序列，字符序列长度≤1000

**输出**
输出为true/false，分别表示输入的字符序列是否为回文

```c
#include<stdio.h>
#include<stdlib.h>

typedef struct Node{
    char data;
    struct Node *next;
}Node;

typedef struct{
    Node *top;
}Stack;

void initStack(Stack *s){
    s->top=NULL;
}

void push(Stack *s,char a){

    Node *newNode=(Node*)malloc(sizeof(Node));

    newNode->data=a;

    newNode->next=s->top;

    s->top=newNode;
}

void pop(Stack *s,char *a){

    if(s->top==NULL)
        return;

    Node *p=s->top;

    *a=p->data;

    s->top=p->next;

    free(p);
}

int charlength(char *a){

    int i=0;

    while(a[i]!='\0'){
        i++;
    }

    return i;
}

int ishw(char *a){

    Stack s;
    int n;
    int i=0;
    char temp;

    initStack(&s);

    n=charlength(a);

    while(i<n/2){

        push(&s,a[i]);

        i++;
    }

    if(n%2!=0){
        i++;
    }

    while(i<n){

        pop(&s,&temp);

        if(a[i]!=temp)
            return 0;

        i++;
    }

    return 1;
}

int main(){

    char a[1000];

    scanf("%s",a);

    if(ishw(a))
        printf("true");
    else
        printf("false");

    return 0;
}

```

